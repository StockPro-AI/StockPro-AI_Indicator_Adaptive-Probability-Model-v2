// StockPro-AI - Adaptive Probability Strategy v1
// Pine Script v6
//@version=6
strategy("StockPro-AI - Adaptive Probability Strategy v1", overlay = true, pyramiding = 10, initial_capital = 100000, commission_type = strategy.commission.percent, commission_value = 0.05)

// =====================================================
// 1) INPUTS
// =====================================================
lookahead       = input.int(10,  "Prediction Horizon (bars)", minval = 1)
trainWindow     = input.int(300, "Training Window", minval = 20)
learningRate    = input.float(0.03, "Learning Rate", step = 0.01, minval = 0.001)
rsiLen          = input.int(14,  "RSI Length", minval = 1)
emaFastLen      = input.int(20,  "EMA Fast", minval = 1)
emaSlowLen      = input.int(200, "EMA Slow", minval = 1)
macdFastLen     = input.int(12,  "MACD Fast", minval = 1)
macdSlowLen     = input.int(26,  "MACD Slow", minval = 1)
macdSignalLen   = input.int(9,   "MACD Signal", minval = 1)
atrLen          = input.int(14,  "ATR Length", minval = 1)
regimeThreshold = input.float(0.75, "Trend Regime Threshold (EMA spread / ATR)", step = 0.05, minval = 0.10)

// Directional signal filters
tradeMode       = input.string("Both", "Trade Mode", options = ["Both", "Long only", "Short only", "None"])
confirmOnClose  = input.bool(true, "Signal Only On Bar Close")
allowReversal   = input.bool(true, "Allow Reversal on Opposite Signal")

// Signal spam protection
signalCooldownBars      = input.int(5, "Min Bars Between Signals", minval = 0)
maxLongSignalsPerTrade   = input.int(3, "Max Long Signals per Trade", minval = 1, maxval = 10)
maxShortSignalsPerTrade  = input.int(3, "Max Short Signals per Trade", minval = 1, maxval = 10)

// Signal quality thresholds
longBiasMin   = input.float(60.0, "Long: Min Long %", minval = 0.0, maxval = 100.0, step = 0.5)
longBiasMax   = input.float(40.0, "Long: Max Short %", minval = 0.0, maxval = 100.0, step = 0.5)
shortBiasMin  = input.float(60.0, "Short: Min Short %", minval = 0.0, maxval = 100.0, step = 0.5)
shortBiasMax  = input.float(40.0, "Short: Max Long %", minval = 0.0, maxval = 100.0, step = 0.5)
minConfidence = input.float(70.0, "Min Confidence %", minval = 0.0, maxval = 100.0, step = 0.5)
minAccuracy   = input.float(55.0, "Min Accuracy %", minval = 0.0, maxval = 100.0, step = 0.5)

// Risk management
stopAtrMult   = input.float(1.5, "Stop Loss ATR Multiplier", minval = 0.1, step = 0.1)
takeAtrMult   = input.float(3.0, "Take Profit ATR Multiplier", minval = 0.1, step = 0.1)
useSession    = input.bool(true, "Use Session Filter")
tradeSession  = input.session("0930-1600", "Trading Session")

// Visuals
showTable      = input.bool(true, "Show Table")
showSignals    = input.bool(true, "Show Signal Arrows")
showExits      = input.bool(false, "Show Exit Markers")
uiPosition     = input.string("Top Right", "Table Position", options = ["Top Left", "Top Right", "Bottom Left", "Bottom Right", "Top Center", "Bottom Center"])
uiSize         = input.string("Medium", "Table Size", options = ["Small", "Medium", "Large"])
longArrowColor  = input.color(color.lime, "Long Arrow Color")
shortArrowColor = input.color(color.red, "Short Arrow Color")
exitColor       = input.color(color.orange, "Exit Marker Color")

f_table_position(pos) =>
    switch pos
        "Top Left"      => position.top_left
        "Top Right"     => position.top_right
        "Bottom Left"   => position.bottom_left
        "Bottom Right"  => position.bottom_right
        "Top Center"    => position.top_center
        "Bottom Center" => position.bottom_center
        => position.top_right

f_text_size(sz) =>
    switch sz
        "Small"  => size.small
        "Medium" => size.normal
        "Large"  => size.large
        => size.normal

f_cell_w(sz) =>
    switch sz
        "Small"  => 4
        "Medium" => 6
        "Large"  => 8
        => 6

f_cell_h(sz) =>
    switch sz
        "Small"  => 3
        "Medium" => 5
        "Large"  => 7
        => 5

uiPos  = f_table_position(uiPosition)
uiText = f_text_size(uiSize)
cellW  = f_cell_w(uiSize)
cellH  = f_cell_h(uiSize)

// =====================================================
// 2) CORE FEATURES
// =====================================================
rsi      = ta.rsi(close, rsiLen)
emaFast  = ta.ema(close, emaFastLen)
emaSlow  = ta.ema(close, emaSlowLen)
atr      = ta.atr(atrLen)
[macdLine, macdSignal, macdHist] = ta.macd(close, macdFastLen, macdSlowLen, macdSignalLen)

emaDiff  = emaFast - emaSlow
macdDiff = macdLine - macdSignal
trendStrength = atr > 0.0 ? math.abs(emaDiff) / atr : 0.0
trendRegime   = trendStrength >= regimeThreshold

rsiNorm  = (rsi - 50.0) / 50.0
emaNorm  = atr > 0.0 ? emaDiff / atr : 0.0
macdNorm = atr > 0.0 ? macdDiff / atr : 0.0

warmupBars = math.max(lookahead + 1, math.max(math.max(rsiLen, atrLen), math.max(emaSlowLen, macdSlowLen + macdSignalLen)) + 5)
isReady = bar_index >= warmupBars and not na(rsi) and not na(emaFast) and not na(emaSlow) and not na(atr) and not na(macdLine) and not na(macdSignal)

// =====================================================
// 3) MODEL
// =====================================================
var float w_rsi  = 0.0
var float w_ema  = 0.0
var float w_macd = 0.0
var float bias   = 0.0

sigmoid(x) => 1.0 / (1.0 + math.exp(-x))
clamp01(x) => math.max(0.0, math.min(1.0, x))
clampScore(x) => math.max(-10.0, math.min(10.0, x))

rawScore = isReady ? clampScore(w_rsi * rsiNorm + w_ema * emaNorm + w_macd * macdNorm + bias) : 0.0
probUp   = isReady ? sigmoid(rawScore) : 0.5

// =====================================================
// 4) DELAYED LEARNING BUFFER
// =====================================================
var array<float> buf_rsi  = array.new_float()
var array<float> buf_ema  = array.new_float()
var array<float> buf_macd = array.new_float()
var array<float> buf_prob = array.new_float()

if isReady
    array.push(buf_rsi, rsiNorm)
    array.push(buf_ema, emaNorm)
    array.push(buf_macd, macdNorm)
    array.push(buf_prob, probUp)

    maxBuffer = math.max(trainWindow, lookahead + 1)
    while array.size(buf_prob) > maxBuffer
        array.shift(buf_rsi)
        array.shift(buf_ema)
        array.shift(buf_macd)
        array.shift(buf_prob)

var int samples = 0
var float accuracyEma = na
alphaAcc = 2.0 / (trainWindow + 1.0)

canLearn = isReady and array.size(buf_prob) > lookahead
if canLearn
    idx = array.size(buf_prob) - lookahead - 1
    pastProb = array.get(buf_prob, idx)
    pastRsi  = array.get(buf_rsi, idx)
    pastEma  = array.get(buf_ema, idx)
    pastMacd = array.get(buf_macd, idx)

    labelUp = close > close[lookahead] ? 1.0 : 0.0
    error   = labelUp - pastProb

    w_rsi  += learningRate * error * pastRsi
    w_ema  += learningRate * error * pastEma
    w_macd += learningRate * error * pastMacd
    bias   += learningRate * error

    w_rsi  := math.max(-2.0, math.min(2.0, w_rsi))
    w_ema  := math.max(-2.0, math.min(2.0, w_ema))
    w_macd := math.max(-2.0, math.min(2.0, w_macd))
    bias   := math.max(-2.0, math.min(2.0, bias))

    predClass = pastProb >= 0.5 ? 1.0 : 0.0
    hit = predClass == labelUp ? 1.0 : 0.0
    samples += 1
    accuracyEma := na(accuracyEma) ? hit : accuracyEma * (1.0 - alphaAcc) + hit * alphaAcc

coverage = clamp01(samples / trainWindow)
quality  = na(accuracyEma) ? 0.0 : clamp01(accuracyEma)
confidence = isReady ? clamp01(0.55 * coverage + 0.45 * quality) : 0.0
regimeBoost = clamp01(trendStrength / math.max(0.0001, regimeThreshold))
confidence := confidence * (0.70 + 0.30 * regimeBoost)

upPct   = isReady ? math.round(probUp * 100.0) : 50
downPct = 100 - upPct
statusText = isReady ? (trendRegime ? "READY / TREND" : "READY / RANGE") : "WARMUP"

// =====================================================
// 5) SIGNAL LOGIC
// =====================================================
barOk = confirmOnClose ? barstate.isconfirmed : true
sessionOk = not useSession or not na(time(timeframe.period, tradeSession))
modeAllowsLong = tradeMode == "Both" or tradeMode == "Long only"
modeAllowsShort = tradeMode == "Both" or tradeMode == "Short only"
qualityOk = confidence * 100.0 >= minConfidence and quality * 100.0 >= minAccuracy

longCore  = isReady and barOk and sessionOk and modeAllowsLong and upPct >= longBiasMin and downPct <= longBiasMax and qualityOk
shortCore = isReady and barOk and sessionOk and modeAllowsShort and downPct >= shortBiasMin and upPct <= shortBiasMax and qualityOk

var int lastLongSignalBar = na
var int lastShortSignalBar = na
var int longSignalsThisTrade = 0
var int shortSignalsThisTrade = 0

posNow  = strategy.position_size
posPrev = strategy.position_size[1]
flatNow = posNow == 0
wasFlat = posPrev == 0

// Reset counters when a trade is fully closed.
if flatNow and not wasFlat
    longSignalsThisTrade := 0
    shortSignalsThisTrade := 0
    lastLongSignalBar := na
    lastShortSignalBar := na

cooldownLongOk = na(lastLongSignalBar) or (bar_index - lastLongSignalBar >= signalCooldownBars)
cooldownShortOk = na(lastShortSignalBar) or (bar_index - lastShortSignalBar >= signalCooldownBars)

canAddLong = posNow > 0 and longSignalsThisTrade < maxLongSignalsPerTrade and cooldownLongOk
canAddShort = posNow < 0 and shortSignalsThisTrade < maxShortSignalsPerTrade and cooldownShortOk
canOpenLong = flatNow or (allowReversal and posNow < 0)
canOpenShort = flatNow or (allowReversal and posNow > 0)

longSignal = false
shortSignal = false
longEntryNow = false
shortEntryNow = false

if longCore
    if canOpenLong and (flatNow or posNow <= 0)
        strategy.entry("L", strategy.long)
        longSignalsThisTrade := 1
        shortSignalsThisTrade := 0
        lastLongSignalBar := bar_index
        lastShortSignalBar := na
        longSignal := true
        longEntryNow := true
    else if canAddLong and posNow > 0
        strategy.entry("L", strategy.long)
        longSignalsThisTrade += 1
        lastLongSignalBar := bar_index
        longSignal := true
        longEntryNow := true

if shortCore
    if canOpenShort and (flatNow or posNow >= 0)
        strategy.entry("S", strategy.short)
        shortSignalsThisTrade := 1
        longSignalsThisTrade := 0
        lastShortSignalBar := bar_index
        lastLongSignalBar := na
        shortSignal := true
        shortEntryNow := true
    else if canAddShort and posNow < 0
        strategy.entry("S", strategy.short)
        shortSignalsThisTrade += 1
        lastShortSignalBar := bar_index
        shortSignal := true
        shortEntryNow := true

// Reversal reset handling
if posPrev > 0 and posNow < 0
    longSignalsThisTrade := 0
    shortSignalsThisTrade := 1
    lastShortSignalBar := bar_index
    lastLongSignalBar := na

if posPrev < 0 and posNow > 0
    shortSignalsThisTrade := 0
    longSignalsThisTrade := 1
    lastLongSignalBar := bar_index
    lastShortSignalBar := na

// =====================================================
// 6) RISK MANAGEMENT
// =====================================================
if strategy.position_size > 0 and isReady
    longStop = strategy.position_avg_price - atr * stopAtrMult
    longTake = strategy.position_avg_price + atr * takeAtrMult
    strategy.exit("LX", from_entry = "L", stop = longStop, limit = longTake)

if strategy.position_size < 0 and isReady
    shortStop = strategy.position_avg_price + atr * stopAtrMult
    shortTake = strategy.position_avg_price - atr * takeAtrMult
    strategy.exit("SX", from_entry = "S", stop = shortStop, limit = shortTake)

exitLongNow = showExits and posPrev > 0 and posNow == 0
exitShortNow = showExits and posPrev < 0 and posNow == 0

// =====================================================
// 7) TABLE
// =====================================================
var table t = table.new(uiPos, 2, 8, border_width = 2, border_color = color.rgb(90, 90, 90), frame_width = 2, frame_color = color.rgb(90, 90, 90))

if showTable and barstate.islast
    headerBg = color.rgb(45, 45, 45)
    bullBg   = upPct >= 60 ? color.rgb(16, 110, 70) : upPct >= 30 ? color.rgb(40, 90, 60) : color.rgb(70, 70, 70)
    bearBg   = downPct >= 60 ? color.rgb(150, 40, 40) : downPct >= 30 ? color.rgb(110, 55, 55) : color.rgb(70, 70, 70)
    infoBg   = trendRegime ? color.rgb(40, 70, 120) : color.rgb(70, 70, 70)
    panelBg  = color.rgb(28, 28, 28)

    table.cell(t, 0, 0, "Metric", bgcolor = headerBg, text_color = color.white, text_size = uiText, width = cellW, height = cellH)
    table.cell(t, 1, 0, "Value",  bgcolor = headerBg, text_color = color.white, text_size = uiText, width = cellW, height = cellH)

    table.cell(t, 0, 1, "Status", bgcolor = infoBg, text_color = color.white, text_size = uiText, width = cellW, height = cellH)
    table.cell(t, 1, 1, statusText, bgcolor = infoBg, text_color = color.white, text_size = uiText, width = cellW, height = cellH)

    table.cell(t, 0, 2, "UP", bgcolor = bullBg, text_color = color.white, text_size = uiText, width = cellW, height = cellH)
    table.cell(t, 1, 2, isReady ? (str.tostring(upPct) + "%") : "n/a", bgcolor = bullBg, text_color = color.white, text_size = size.huge, width = cellW, height = cellH)

    table.cell(t, 0, 3, "DOWN", bgcolor = bearBg, text_color = color.white, text_size = uiText, width = cellW, height = cellH)
    table.cell(t, 1, 3, isReady ? (str.tostring(downPct) + "%") : "n/a", bgcolor = bearBg, text_color = color.white, text_size = size.huge, width = cellW, height = cellH)

    table.cell(t, 0, 4, "Confidence", bgcolor = panelBg, text_color = color.white, text_size = uiText, width = cellW, height = cellH)
    table.cell(t, 1, 4, isReady ? (str.tostring(math.round(confidence * 100.0)) + "%") : "n/a", bgcolor = panelBg, text_color = color.white, text_size = size.huge, width = cellW, height = cellH)

    table.cell(t, 0, 5, "Accuracy", bgcolor = panelBg, text_color = color.white, text_size = uiText, width = cellW, height = cellH)
    table.cell(t, 1, 5, na(accuracyEma) ? "n/a" : str.tostring(math.round(accuracyEma * 100.0)) + "%", bgcolor = panelBg, text_color = color.white, text_size = size.huge, width = cellW, height = cellH)

    table.cell(t, 0, 6, "Long Signals", bgcolor = panelBg, text_color = color.white, text_size = uiText, width = cellW, height = cellH)
    table.cell(t, 1, 6, str.tostring(longSignalsThisTrade) + " / " + str.tostring(maxLongSignalsPerTrade), bgcolor = panelBg, text_color = color.white, text_size = uiText, width = cellW, height = cellH)

    table.cell(t, 0, 7, "Short Signals", bgcolor = panelBg, text_color = color.white, text_size = uiText, width = cellW, height = cellH)
    table.cell(t, 1, 7, str.tostring(shortSignalsThisTrade) + " / " + str.tostring(maxShortSignalsPerTrade), bgcolor = panelBg, text_color = color.white, text_size = uiText, width = cellW, height = cellH)

// =====================================================
// 8) VISUALS + ALERTS
// =====================================================
plot(probUp, title = "Probability Up", linewidth = 2, color = color.new(color.lime, 0))
plot(1.0 - probUp, title = "Probability Down", linewidth = 2, color = color.new(color.red, 0))

plotshape(showSignals and longEntryNow, title = "Long Entry", style = shape.arrowup, location = location.belowbar, color = color.new(longArrowColor, 0), size = size.small, text = longSignalsThisTrade > 1 ? "LONG+" : "LONG", textcolor = color.white)
plotshape(showSignals and shortEntryNow, title = "Short Entry", style = shape.arrowdown, location = location.abovebar, color = color.new(shortArrowColor, 0), size = size.small, text = shortSignalsThisTrade > 1 ? "SHORT+" : "SHORT", textcolor = color.white)
plotshape(exitLongNow, title = "Long Exit", style = shape.xcross, location = location.abovebar, color = color.new(exitColor, 0), size = size.tiny, text = "LX", textcolor = color.white)
plotshape(exitShortNow, title = "Short Exit", style = shape.xcross, location = location.belowbar, color = color.new(exitColor, 0), size = size.tiny, text = "SX", textcolor = color.white)

alertcondition(longEntryNow, title = "StockPro-AI Strategy Long Entry", message = "StockPro-AI - Adaptive Probability Strategy v1: LONG entry")
alertcondition(shortEntryNow, title = "StockPro-AI Strategy Short Entry", message = "StockPro-AI - Adaptive Probability Strategy v1: SHORT entry")
alertcondition(exitLongNow, title = "StockPro-AI Strategy Long Exit", message = "StockPro-AI - Adaptive Probability Strategy v1: LONG exit")
alertcondition(exitShortNow, title = "StockPro-AI Strategy Short Exit", message = "StockPro-AI - Adaptive Probability Strategy v1: SHORT exit")
